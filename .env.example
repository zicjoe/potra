# Potra frontend configuration
# Local Portaldot node from Discord/docs
VITE_CHAIN_ENV=local
VITE_PORTALDOT_RPC=ws://127.0.0.1:9944
VITE_PORTALDOT_EXPLORER=https://polkadot.js.org/apps/?rpc=ws%3A%2F%2F127.0.0.1%3A9944#/explorer
VITE_FAUCET_API=http://localhost:8787
VITE_POT_DECIMALS=14
VITE_SS58_FORMAT=42

# Real EVM testnet bridge vaults. Fill these after deploying contracts/evm/PotraBridgeVault.sol.
VITE_SEPOLIA_BRIDGE_VAULT=
VITE_BNB_BRIDGE_VAULT=
VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
VITE_BNB_TESTNET_RPC_URL=https://bsc-testnet.publicnode.com

# These contract values are empty until we deploy the full ink! AMM contract phase.
VITE_POTRA_FACTORY_CONTRACT=
VITE_POTRA_ROUTER_CONTRACT=
VITE_POTRA_POOL_FACTORY_CONTRACT=
