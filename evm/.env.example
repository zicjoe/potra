# Use a fresh deployer wallet funded only with testnet ETH/BNB.
# Do not use a wallet that holds mainnet funds.
DEPLOYER_PRIVATE_KEY=

# Public RPC defaults. You can replace them with Alchemy/Infura/QuickNode if needed.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
BNB_TESTNET_RPC_URL=https://bsc-testnet.publicnode.com
